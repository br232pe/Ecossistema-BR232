# --- CONFIGURAÇÃO DO FIREBASE (Banco de Dados e Auth) ---
# A configuração do Firebase é gerenciada automaticamente pelo arquivo:
# firebase-applet-config.json

# --- INTELIGÊNCIA ARTIFICIAL (Gemini) ---
# O Gemini API Key é injetado automaticamente pelo ambiente.
# Se precisar configurar localmente, use:
GEMINI_API_KEY=

# --- GOOGLE MAPS ---
# Obtenha em: https://console.cloud.google.com/google/maps-apis/credentials
VITE_GOOGLE_MAPS_KEY=

# --- CONFIGURAÇÃO GERAL ---
VITE_APP_VERSION=1.0.0-beta
